{
    "name": "@app/common",
    "version": "1.0.0",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "setupFiles": [
            "<rootDir>/jest.setup.ts"
        ],
        "testEnvironment": "node"
    },
    "peerDependencies": {
        "@nestjs/common": "^11.1.17",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "dotenv": "^17.3.1"
    },
    "dependencies": {
        "luxon": "^3.7.2"
    },
    "devDependencies": {
        "@types/luxon": "^3.7.1"
    }
}
