generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String   @id
  type        String
  emittedAt   DateTime @db.Timestamptz(3)
  receivedAt  DateTime @db.Timestamptz(3)
  processedAt DateTime @db.Timestamptz(3)
  properties  Json?
}

model DailyEventStat {
  date      DateTime @db.Date
  eventType String
  count     Int
  timeZone  String

  @@id([date, eventType, timeZone])
}
