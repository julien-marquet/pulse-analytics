generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String   @id
  type        String
  emittedAt   DateTime @db.Timestamptz(3)
  receivedAt  DateTime @db.Timestamptz(3)
  processedAt DateTime @db.Timestamptz(3)
  properties  Json?

  @@index([emittedAt(sort: Desc)])
  @@index([type])
}

model DailyEventStat {
  date                     DateTime @db.Date
  eventType                String
  count                    Int
  timeZone                 String
  processingLatencyTotalMs Int

  @@id([date, eventType, timeZone])
  @@index([timeZone, date])
}
