generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String    @id
  type        String
  receivedAt  DateTime
  processedAt DateTime?
  properties  Json?
}

model DailyEventsStats {
  date  DateTime
  type  String
  count Int
  @@id([date, type])
}
