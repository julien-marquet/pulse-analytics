generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id          String   @id
  type        String
  receivedAt  DateTime @db.Timestamptz(3)
  processedAt DateTime @db.Timestamptz(3)
  properties  Json?
}

model DailyEventsStats {
  date     DateTime @db.Date
  type     String
  count    Int
  timeZone String
  
  @@id([date, type, timeZone])
}
